---
interface Props {
  t: any;
}

const { t } = Astro.props;

const iconSvgs = [
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7"><path d="M12 21a9 9 0 100-18 9 9 0 000 18z"/><path d="M3.6 9h16.8M3.6 15h16.8"/><path d="M12 3a15.3 15.3 0 014 9 15.3 15.3 0 01-4 9 15.3 15.3 0 01-4-9 15.3 15.3 0 014-9z"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7"><path d="M4 17l6-6-6-6"/><path d="M12 19h8"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7"><rect x="5" y="2" width="14" height="20" rx="2"/><path d="M12 18h.01"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7"><path d="M18 20V10M12 20V4M6 20v-6"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7"><path d="M12 19l7-7 3 3-7 7-3-3z"/><path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/><path d="M2 2l7.586 7.586"/><circle cx="11" cy="11" r="2"/></svg>`,
];
---

<section id="services" data-animate class="relative py-24 px-6 overflow-hidden">
  <!-- Background accent -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-1/2 h-px bg-gradient-to-r from-transparent via-accent/30 to-transparent"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] rounded-full opacity-20" style="background: radial-gradient(circle, rgba(239,68,68,0.08) 0%, transparent 70%);"></div>

  <div class="max-w-6xl mx-auto">
    <!-- Section number -->
    <div class="text-center mb-16 relative">
      <div class="absolute left-1/2 -translate-x-1/2 -top-8 text-[140px] font-black text-white/[0.015] leading-none select-none pointer-events-none" style="font-family: 'Unbounded', sans-serif;">01</div>
      <p class="section-label" style="font-family:'Unbounded','Inter',sans-serif; font-size:0.75rem; letter-spacing:0.25em;">{t.services.label}</p>
      <h2 class="section-heading mt-4" style="font-family:'Unbounded','Inter',sans-serif; font-size:clamp(1.75rem,4vw,2.75rem); letter-spacing:-0.03em; line-height:1.15;">{t.services.heading}</h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {t.services.items.map((item: any, i: number) => (
        <div class="group relative rounded-2xl p-6 border border-white/[0.06] bg-white/[0.02] hover:border-accent/30 hover:bg-accent/[0.04] transition-all duration-500 cursor-default">
          <div class="absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500" style="background: radial-gradient(circle at 50% 0%, rgba(239,68,68,0.08) 0%, transparent 70%);"></div>
          <div class="relative z-10">
            <div class="w-14 h-14 rounded-xl bg-accent/10 border border-accent/20 flex items-center justify-center text-accent mb-5 group-hover:bg-accent/15 group-hover:border-accent/30 transition-all duration-500 group-hover:shadow-[0_0_20px_rgba(239,68,68,0.15)]">
              <Fragment set:html={iconSvgs[i]} />
            </div>
            <h3 class="font-semibold text-base text-white">{item.title}</h3>
            <p class="text-muted text-sm mt-2 leading-relaxed">{item.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
