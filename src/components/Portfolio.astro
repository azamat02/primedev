---
interface Props {
  t: any;
}

const { t } = Astro.props;
---

<section id="portfolio" data-animate class="relative py-24 px-6 overflow-hidden">
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-1/2 h-px bg-gradient-to-r from-transparent via-accent/30 to-transparent"></div>
  <div class="absolute bottom-0 right-0 w-[400px] h-[400px] rounded-full opacity-20" style="background: radial-gradient(circle, rgba(239,68,68,0.06) 0%, transparent 70%);"></div>

  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16 relative">
      <div class="absolute left-1/2 -translate-x-1/2 -top-8 text-[140px] font-black text-white/[0.015] leading-none select-none pointer-events-none" style="font-family: 'Unbounded', sans-serif;">02</div>
      <p class="section-label" style="font-family:'Unbounded',sans-serif; font-size:0.75rem; letter-spacing:0.25em;">{t.portfolio.label}</p>
      <h2 class="section-heading mt-4" style="font-family:'Unbounded',sans-serif; font-size:clamp(1.75rem,4vw,2.75rem); letter-spacing:-0.03em; line-height:1.15;">{t.portfolio.heading}</h2>
      <p class="text-body text-base mt-4 max-w-lg mx-auto">{t.portfolio.subtitle}</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      {t.portfolio.items.map((item: any) => (
        <div class="group relative overflow-hidden rounded-2xl p-7 border border-white/[0.06] bg-white/[0.02] hover:border-accent/20 transition-all duration-500">
          <div class="absolute -top-2 -right-2 text-[80px] font-black text-accent/[0.04] select-none leading-none group-hover:text-accent/[0.08] transition-colors duration-500" style="font-family: 'Unbounded', sans-serif;">
            {item.number}
          </div>
          <div class="absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500" style="background: radial-gradient(circle at 50% 0%, rgba(239,68,68,0.06) 0%, transparent 60%);"></div>
          <div class="relative z-10">
            <p class="text-[11px] text-accent uppercase tracking-widest font-medium">{item.category}</p>
            <h3 class="text-xl font-bold mt-2" style="font-family: 'Unbounded', sans-serif;">{item.title}</h3>
            <p class="text-body text-sm mt-3 leading-relaxed">{item.description}</p>
            <div class="flex flex-wrap gap-2 mt-4">
              {item.tags.map((tag: string) => (
                <span class="bg-accent/[0.08] text-accent/80 text-xs px-3 py-1 rounded-full border border-accent/10">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
