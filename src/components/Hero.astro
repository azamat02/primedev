---
interface Props {
  t: any;
}

const { t } = Astro.props;
---

<section class="relative overflow-hidden min-h-[90vh] flex items-center justify-center px-6">
  <!-- Grid background with dots at intersections -->
  <div class="hero-grid absolute inset-0"></div>

  <!-- Subtle center glow (no squares) -->
  <div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] rounded-full opacity-30" style="background: radial-gradient(ellipse, rgba(239,68,68,0.15) 0%, transparent 70%);"></div>

  <div class="relative z-10 text-center max-w-4xl mx-auto">
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-white/[0.08] bg-white/[0.03] mb-8">
      <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse"></span>
      <span class="text-xs tracking-widest text-body uppercase">{t.hero.label}</span>
    </div>

    <h1 class="text-5xl md:text-7xl font-bold leading-[1.08] tracking-tight">
      {t.hero.heading}<br />
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent via-red-400 to-accent">{t.hero.headingAccent}</span>
    </h1>

    <p class="text-body text-lg md:text-xl mt-6 max-w-2xl mx-auto leading-relaxed">{t.hero.description}</p>

    <div class="mt-10 flex gap-4 justify-center flex-wrap">
      <!-- Animated button with border glow -->
      <a href="#contact" class="hero-btn group relative">
        <span class="hero-btn-bg"></span>
        <span class="hero-btn-content">
          {t.hero.cta}
          <svg class="inline-block ml-2 w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </span>
      </a>
      <a href="#portfolio" class="btn-outline">{t.hero.ctaSecondary}</a>
    </div>

    <!-- Stats bar -->
    <div class="mt-20 flex items-center justify-center gap-8 md:gap-16">
      <div class="text-center">
        <div class="text-3xl md:text-4xl font-bold text-white">50<span class="text-accent">+</span></div>
        <div class="text-muted text-xs mt-1 uppercase tracking-wider">проектов</div>
      </div>
      <div class="w-px h-12 bg-white/10"></div>
      <div class="text-center">
        <div class="text-3xl md:text-4xl font-bold text-white">3<span class="text-accent">+</span></div>
        <div class="text-muted text-xs mt-1 uppercase tracking-wider">года</div>
      </div>
      <div class="w-px h-12 bg-white/10"></div>
      <div class="text-center">
        <div class="text-3xl md:text-4xl font-bold text-white">24<span class="text-accent">/7</span></div>
        <div class="text-muted text-xs mt-1 uppercase tracking-wider">поддержка</div>
      </div>
    </div>
  </div>

  <!-- Bottom gradient fade -->
  <div class="absolute bottom-0 left-0 right-0 h-40 bg-gradient-to-t from-bg to-transparent"></div>
</section>

<style>
  /* Grid with dots at intersections — like Notchy */
  .hero-grid {
    --grid-size: 64px;
    --line-color: rgba(255, 255, 255, 0.04);
    --dot-color: rgba(255, 255, 255, 0.12);
    --dot-size: 1px;
    background-image:
      /* grid lines */
      linear-gradient(var(--line-color) 1px, transparent 1px),
      linear-gradient(90deg, var(--line-color) 1px, transparent 1px),
      /* dots at intersections */
      radial-gradient(circle var(--dot-size) at 0 0, var(--dot-color) 100%, transparent 100%);
    background-size:
      var(--grid-size) var(--grid-size),
      var(--grid-size) var(--grid-size),
      var(--grid-size) var(--grid-size);
    mask-image: radial-gradient(ellipse 80% 70% at 50% 40%, black 20%, transparent 100%);
    -webkit-mask-image: radial-gradient(ellipse 80% 70% at 50% 40%, black 20%, transparent 100%);
  }

  /* Animated CTA button */
  .hero-btn {
    position: relative;
    display: inline-flex;
    padding: 2px;
    border-radius: 12px;
    overflow: hidden;
    cursor: pointer;
    text-decoration: none;
  }

  /* Spinning gradient border */
  .hero-btn-bg {
    position: absolute;
    inset: 0;
    border-radius: 12px;
    background: conic-gradient(
      from var(--btn-angle, 0deg),
      #ef4444,
      #ff6b6b,
      #ef444480,
      #ef444420,
      #ef444480,
      #ff6b6b,
      #ef4444
    );
    animation: btn-spin 3s linear infinite;
  }

  .hero-btn-content {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    padding: 14px 32px;
    border-radius: 10px;
    background: #0a0a0f;
    color: white;
    font-size: 14px;
    font-weight: 600;
    transition: all 0.3s;
  }

  .hero-btn:hover .hero-btn-content {
    background: rgba(239, 68, 68, 0.15);
  }

  @keyframes btn-spin {
    to { --btn-angle: 360deg; }
  }

  @property --btn-angle {
    syntax: '<angle>';
    initial-value: 0deg;
    inherits: false;
  }
</style>
