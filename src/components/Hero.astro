---
interface Props {
  t: any;
}

const { t } = Astro.props;
---

<section class="relative overflow-hidden min-h-[90vh] flex items-center justify-center px-6 grid-bg noise">
  <!-- Glow orbs -->
  <div class="glow-orb animate-pulse-glow w-[500px] h-[500px] bg-accent/20 -top-40 left-1/2 -translate-x-1/2"></div>
  <div class="glow-orb w-[300px] h-[300px] bg-accent/10 bottom-20 -left-20"></div>
  <div class="glow-orb w-[200px] h-[200px] bg-red-900/20 top-40 -right-10"></div>

  <!-- Decorative lines -->
  <div class="absolute top-0 left-1/2 w-px h-32 bg-gradient-to-b from-transparent via-accent/20 to-transparent"></div>
  <div class="absolute bottom-0 left-1/2 w-px h-32 bg-gradient-to-t from-transparent via-accent/20 to-transparent"></div>

  <div class="relative z-10 text-center max-w-4xl mx-auto">
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-accent/20 bg-accent/5 mb-8">
      <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse"></span>
      <span class="text-xs tracking-widest text-accent/80 uppercase">{t.hero.label}</span>
    </div>

    <h1 class="text-5xl md:text-7xl font-bold leading-[1.1] tracking-tight">
      {t.hero.heading}<br />
      <span class="relative">
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent via-red-400 to-accent">{t.hero.headingAccent}</span>
      </span>
    </h1>

    <p class="text-body text-lg md:text-xl mt-6 max-w-2xl mx-auto leading-relaxed">{t.hero.description}</p>

    <div class="mt-10 flex gap-4 justify-center flex-wrap">
      <a href="#contact" class="btn-primary group">
        {t.hero.cta}
        <svg class="inline-block ml-2 w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
      <a href="#portfolio" class="btn-outline">{t.hero.ctaSecondary}</a>
    </div>

    <!-- Stats bar -->
    <div class="mt-16 flex items-center justify-center gap-8 md:gap-16">
      <div class="text-center">
        <div class="text-3xl md:text-4xl font-bold text-white">50<span class="text-accent">+</span></div>
        <div class="text-muted text-xs mt-1 uppercase tracking-wider">проектов</div>
      </div>
      <div class="w-px h-12 bg-white/10"></div>
      <div class="text-center">
        <div class="text-3xl md:text-4xl font-bold text-white">3<span class="text-accent">+</span></div>
        <div class="text-muted text-xs mt-1 uppercase tracking-wider">года</div>
      </div>
      <div class="w-px h-12 bg-white/10"></div>
      <div class="text-center">
        <div class="text-3xl md:text-4xl font-bold text-white">24<span class="text-accent">/7</span></div>
        <div class="text-muted text-xs mt-1 uppercase tracking-wider">поддержка</div>
      </div>
    </div>
  </div>

  <!-- Bottom gradient fade -->
  <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-bg to-transparent"></div>
</section>
